# Watchly Stremio addon configuration.
# HOST_NAME is resolved at compose time from the root .env WATCHLY_HOSTNAME value,
# mirroring how upstream apps reference ${*_HOSTNAME}.
HOST_NAME=https://${WATCHLY_HOSTNAME?}

PORT=8000
REDIS_URL=redis://watchly-redis:6379/0

ADDON_ID=com.bimal.watchly
ADDON_NAME=Watchly
TOKEN_TTL_SECONDS=0
AUTO_UPDATE_CATALOGS=true

# Filled in automatically by hosting/modules/watchly.sh (random value).
TOKEN_SALT=

# Optional. Prompted by hosting/modules/watchly.sh; may be left empty to skip.
TMDB_API_KEY=
