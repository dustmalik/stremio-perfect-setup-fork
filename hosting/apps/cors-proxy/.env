PORT=8080

# Only requests from these browser origins are allowed.
# Comma-separated full origins. Exact matches are allowed.
# Wildcards are supported on the hostname as leading dots or *.,
# e.g. https://example.com,https://*.example.com,https://.example.com
ALLOWED_ORIGINS=https://${DOMAIN?},https://*.${DOMAIN?}

# Only these target API hostnames can be proxied.
# Comma-separated hostnames. Exact matches are allowed.
# Wildcards are supported as leading dots or *., e.g. .api.example.com or *.api.example.com
ALLOWED_TARGET_HOSTS=*

# Require at least one of these headers to reduce casual open-proxy abuse.
REQUIRE_HEADERS=origin,x-requested-with

# Response cache duration for successful CORS preflight checks, in seconds.
CORS_MAX_AGE=600
